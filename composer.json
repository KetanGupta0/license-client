{
    "name": "finext/license-client",
    "description": "Client SDK for self-hosted Finext products to activate, verify, and heartbeat against the Finext License Server.",
    "type": "library",
    "license": "proprietary",
    "require": {
        "php": "^8.2",
        "ext-sodium": "*",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/http": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/console": "^10.0|^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Finext\\LicenseClient\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Finext\\LicenseClient\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Finext\\LicenseClient\\LicenseClientServiceProvider"
            ],
            "aliases": {
                "License": "Finext\\LicenseClient\\Facades\\License"
            }
        }
    },
    "minimum-stability": "stable"
}
